# Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase Configuration
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Google Drive API Configuration (Service Account)
GOOGLE_CLIENT_EMAIL=your_google_client_email_here
# Note: Private key must be wrapped in quotes and contain actual newlines or escaped \n
GOOGLE_PRIVATE_KEY="your_google_private_key_here"
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id_here

# Scheduler Configuration (Default 8:00 AM Vietnam Time: '0 8 * * *')
CRON_TIME="0 8 * * *"

# Optional: Port or environment variables if needed
NODE_ENV=development

# TTS Voice Configuration (e.g. vi-VN-HoaiMyNeural or vi-VN-NamMinhNeural)
TTS_VOICE=vi-VN-NamMinhNeural

# TikTok Content Posting API Configuration (Direct Post v2)
TIKTOK_CLIENT_KEY=your_tiktok_client_key_here
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret_here
TIKTOK_ACCESS_TOKEN=your_tiktok_access_token_here
TIKTOK_REFRESH_TOKEN=your_tiktok_refresh_token_here
